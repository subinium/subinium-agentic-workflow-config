{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git branch:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git stash:*)",
      "Bash(git show:*)",
      "Bash(git rev-parse:*)",
      "Bash(npm run lint:*)",
      "Bash(npm run build:*)",
      "Bash(npm run test:*)",
      "Bash(npm run dev:*)",
      "Bash(npm ci:*)",
      "Bash(npx tsc:*)",
      "Bash(npx tsx:*)",
      "Bash(npx prettier:*)",
      "Bash(npx biome:*)",
      "Bash(npx next:*)",
      "Bash(npx create-next-app:*)",
      "Bash(python3:*)",
      "Bash(pip install:*)",
      "Bash(pip list:*)",
      "Bash(pytest:*)",
      "Bash(black:*)",
      "Bash(ruff:*)",
      "Bash(mypy:*)",
      "Bash(uv:*)",
      "Bash(ls:*)",
      "Bash(tree:*)",
      "Bash(wc:*)",
      "Bash(which:*)",
      "Bash(pwd:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(echo:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(sleep:*)",
      "Bash(kill:*)",
      "Bash(lsof:*)",
      "Bash(gh api:*)",
      "Bash(gh pr:*)",
      "Bash(gh issue:*)",
      "Bash(gh run:*)",
      "Bash(node:*)",
      "Bash(pnpm:*)",
      "Bash(yarn:*)",
      "Bash(bun:*)",
      "Bash(cargo:*)",
      "Bash(rustup:*)",
      "Bash(docker ps:*)",
      "Bash(docker logs:*)",
      "Bash(docker build:*)",
      "Bash(docker run:*)",
      "Bash(vercel:*)",
      "Bash(curl https://api.github.com/*)",
      "Bash(curl https://api.vercel.com/*)",
      "Bash(curl https://api.anthropic.com/*)",
      "Bash(curl https://raw.githubusercontent.com/*)",
      "Bash(curl http://localhost:*)",
      "Bash(curl http://127.0.0.1:*)",
      "Bash(jq:*)",
      "Bash(npm audit:*)",
      "Bash(pip audit:*)",
      "WebSearch",
      "WebFetch"
    ],
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/.envrc)",
      "Read(**/secrets/**)",
      "Read(**/*credentials*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*id_rsa*)",
      "Read(**/*id_ed25519*)",
      "Read(**/*id_ecdsa*)",
      "Read(**/*id_dsa*)",
      "Read(**/.ssh/**)",
      "Read(**/.aws/credentials)",
      "Read(**/.aws/config)",
      "Read(**/.npmrc)",
      "Read(**/.netrc)",
      "Read(**/kubeconfig)",
      "Read(**/.kube/config)",
      "Read(**/*.sqlite)",
      "Read(**/*.db)",
      "Write(**/.env)",
      "Write(**/.env.*)",
      "Write(**/.envrc)",
      "Write(**/secrets/**)",
      "Write(**/.ssh/**)",
      "Write(**/.aws/**)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/session-context.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/session-guard.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/block-destructive-git.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/guard-bash-secrets.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Read|Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/guard-sensitive-files.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/format-on-save.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/warn-large-files.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "auto|manual",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/precompact-handoff.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/precompact-handoff.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "matcher": "rate_limit|authentication_failed|billing_error|server_error",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/log-stop-failure.sh",
            "timeout": 3
          }
        ]
      }
    ]
  }
}
